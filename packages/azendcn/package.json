{
  "name": "azendcn",
  "version": "0.1.0",
  "description": "A React component library with Tailwind CSS — like Shadcn, but yours.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "clsx": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "clsx": {
      "optional": false
    }
  },
  "keywords": [
    "react",
    "components",
    "tailwind",
    "ui",
    "shadcn"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "clsx": "^2.1.1",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
